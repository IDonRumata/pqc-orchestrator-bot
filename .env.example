# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Telegram ---------------------------------------------------------------
# Token from @BotFather
TELEGRAM_BOT_TOKEN=000000000:replace-with-your-token
# Comma separated whitelist of Telegram numeric user ids allowed to use the bot.
# An empty value locks the bot down for everyone. Find your id via @userinfobot.
ALLOWED_USER_IDS=123456789

# --- OpenRouter (LLM provider) ---------------------------------------------
OPENROUTER_API_KEY=sk-or-replace-with-your-key

# --- OpenAI (optional, only for higher quality embeddings) -----------------
# Leave empty to use the free local fastembed model only.
OPENAI_API_KEY=

# --- Database (used by docker-compose) -------------------------------------
POSTGRES_USER=pqc
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=pqc_orchestrator
# When running the bot outside Docker, set DATABASE_URL directly, for example:
# DATABASE_URL=postgresql+asyncpg://pqc:change-this-strong-password@127.0.0.1:5432/pqc_orchestrator

# --- Observability ----------------------------------------------------------
LOG_LEVEL=INFO

# --- Model matrix (OpenRouter slugs, 2026 defaults, override as needed) -----
ROUTER_MODEL=google/gemini-2.5-flash
NEWS_CLASSIFIER_MODEL=google/gemini-2.5-flash
CFO_MODEL=openai/gpt-4o-mini
PQC_MODEL=anthropic/claude-sonnet-4.5
LEGAL_MODEL=anthropic/claude-sonnet-4.5
GRANTS_MODEL=anthropic/claude-sonnet-4.5
CRITIC_MODEL=anthropic/claude-opus-4.1
